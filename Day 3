#to print pairs we need count

#include<iostream>
using namespace std;
int main(){
    int a[]={2,4,6,8};
    int n=sizeof(a)/sizeof(a[0]);
    int target=10;
    int count=0;
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if(a[i]+a[j]==target){
                cout<<a[i]<<" "<<a[j]<<endl;
                cout<<target<<endl;
                count++;
                cout<<count;
                
            }
        }
    }
}

