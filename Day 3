# two sum

#include<iostream>
using namespace std;
int main(){
    int nums[]={2,5,8,9};
    int n=sizeof(nums)/sizeof(nums[0]);
    int target=13;
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
           if(nums[i]+nums[j]==target){
               cout<<nums[i]<<" "<<nums[j]<<endl;
               cout<<target;
           }
          
        }
    }
   
}

