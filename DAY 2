5.//whether minor or adult using parameter

#include<iostream>
using namespace std;
void age(int a){
   if(a>=18){
       cout<<"adult";
   }
   else{
       cout<<"minor";
   }

}
int main(){
    int a;
    cin>>a;
    age(a);
    return 0;
}

