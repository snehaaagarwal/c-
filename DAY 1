9.//Sum of first n numbers

#include<iostream>
using namespace std;
int main(){
   int n;
   int sum=0;
   cin>>n;
   for(int i=1;i<=n;i++){
       sum=sum+i;
   }
   cout<<"sum of first"<<" "<<n<<" "<<"is"<<" "<<sum;
   return 0;
}
