7.//Print second largest

#include<iostream>
using namespace std;
int main(){
    int a,b,c;
    cout<<"enter the no:";
    cin>>a>>b>>c;
    
    if((a>b && a<c)||(a>c && a<b)){
        cout<<"Second largest a";
    }
    else if((b>a && b<c)||(b>c && b<a)){
        cout<<"Second largest b";
    }
    else{
        cout<<"Second largest c";
    }
    return 0;
}

